          "audioSrc": "public/data/audio/dummy/dummy_046_sideB_3.mp3"
        }
      ],
      "note": null
    },
    {
      "cardId": "dummy_047",
      "cardType": "flippable",
      "sideA": "Ha tomado tiempo lograrlo.",
      "sideB": [
        {
          "text": "It has taken time to achieve it.",
          "audioSrc": "public/data/audio/dummy/dummy_047_sideB_0.mp3"
        },
        {
          "text": "It's taken time to get it done.",
          "audioSrc": "public/data/audio/dummy/dummy_047_sideB_1.mp3"
