    {
      "cardId": "dummy_220",
      "cardType": "flippable",
      "sideA": "El día de antes de ayer ocurrió.",
      "sideB": [
        {
          "text": "It happened the day before yesterday.",
          "audioSrc": "public/data/audio/dummy/dummy_220_sideB_0.mp3"
        },
        {
          "text": "It occurred the day before yesterday.",
          "audioSrc": "public/data/audio/dummy/dummy_220_sideB_1.mp3"
        },
        {
          "text": "That happened the day before yesterday.",
          "audioSrc": "public/data/audio/dummy/dummy_220_sideB_2.mp3"
        },
        {
          "text": "That occurred the day before yesterday.",
          "audioSrc": "public/data/audio/dummy/dummy_220_sideB_3.mp3"
        }
      ],
      "note": "~The day before yesterday occurred~ is incorrect because it implies the day itself was an event that happened. You need a dummy subject like [It] or [That] to represent the event, as in [It occurred the day before yesterday]."
    },
    {
      "cardId": "dummy_221",
      "cardType": "flippable",
      "sideA": "¿Puedes invitarme a la reunión, por favor?",
      "sideB": [
        {
          "text": "Can you please invite me to the meeting?",
          "audioSrc": "public/data/audio/dummy/dummy_221_sideB_0.mp3"
        },
        {
          "text": "Could you invite me to the meeting, please?",
          "audioSrc": "public/data/audio/dummy/dummy_221_sideB_1.mp3"
        },
        {
          "text": "Can you send me an invite to the meeting, please?",
